<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="EditText" parent="@style/Widget.AppCompat.EditText">
        <item name="trackColor">@color/black</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:textColorHint">#6A6A6A</item>
        <item name="background">@drawable/edittext_backround</item>
        <item name="fontFamily">@font/inclined</item>
    </style>
    <style name="Button" parent="@style/Widget.AppCompat.EditText">
        <item name=""></item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="background">@drawable/button_background</item>
        <item name="fontFamily">@font/inclined</item>
        <item name="android:gravity">center</item>
    </style>
</resources>